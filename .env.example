# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Image model to use for generation (default: gpt-image-2-2026-04-21)
OPENAI_IMAGE_MODEL=gpt-image-2-2026-04-21

# Vision model used to read each panel and produce per-bubble translations
# before the image model renders them (default: gpt-5.2).
OPENAI_TRANSLATOR_MODEL=gpt-5.2

# HMAC secret for signing the daily-quota cookie (min 16 chars, random).
# Generate with: openssl rand -hex 32
QUOTA_SECRET=change-me-to-a-long-random-string-at-least-16-chars

# Allowed origin for /api/translate POSTs. Cross-origin requests from any
# other site are rejected with 403 to prevent anonymous OpenAI cost abuse.
# Set to your production URL in Vercel (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://your-domain.example.com

# Token gating /api/debug. Without ?token=<value>, the endpoint returns 404.
# Generate with: openssl rand -hex 24
DEBUG_TOKEN=change-me-to-a-random-string

# Google AdSense — get your publisher ID at https://adsense.google.com
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Ad slot IDs (from your AdSense account)
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=XXXXXXXXXX
