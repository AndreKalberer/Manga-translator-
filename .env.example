# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Image model to use for generation (default: gpt-image-1.5)
OPENAI_IMAGE_MODEL=gpt-image-1.5

# Google AdSense — get your publisher ID at https://adsense.google.com
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Ad slot IDs (from your AdSense account)
NEXT_PUBLIC_ADSENSE_SLOT_HEADER=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=XXXXXXXXXX
